{
  "package": "br.com.intermedium",
  "variables": {
    "senhas": ["101080Ma@"],
    "chaves_pix_file": "chaves_pix.txt"
  },
  "launch": {
    "wait_identifier": {"className": "android.widget.EditText"},
    "timeout": 15
  },
  "steps": [
    {
      "name": "Aguardar campo de senha",
      "action": "wait",
      "target": {"classe": "android.widget.EditText"},
      "timeout": 10,
      "retries": 2,
      "retry_delay": 0.2
    },
    {
      "name": "Digitar senha",
      "action": "type",
      "target": {"classe": "android.widget.EditText"},
      "value": "$senhas.0",
      "timeout": 8,
      "retries": 2,
      "retry_delay": 0.2
    },
    {
      "name": "Clicar em Entrar",
      "action": "click",
      "target": [
        {"texto_contem": ["Entrar", "Login", "Sign in", "OK"]},
        {"classe": "android.widget.Button"}
      ],
      "timeout": 8,
      "retries": 2,
      "retry_delay": 0.2,
      "on_failure": ["delay:1"]
    },
    {
      "name": "Aguardar saldo (R$)",
      "action": "wait",
      "target": [{"texto_contem": ["R$", "Saldo", "Balance"]}, {"classe": "android.widget.TextView"}],
      "timeout": 10,
      "retries": 2,
      "retry_delay": 0.2
    },
    {
      "name": "Extrair saldo",
      "action": "extract",
      "target": [{"texto_contem": ["R$", "Saldo", "Balance"]}, {"classe": "android.widget.TextView"}],
      "save_as": "saldo",
      "timeout": 5,
      "retries": 2,
      "retry_delay": 0.2
    },
    {
      "name": "Logar saldo",
      "action": "log",
      "message": "💰 Saldo extraído: $saldo"
    },
    {
      "name": "Clicar em Pix",
      "action": "click",
      "target": [{"texto_contem": ["Pix", "Payments", "Pagamentos"]}, {"classe": "android.widget.Button"}],
      "timeout": 8,
      "retries": 2,
      "retry_delay": 0.2
    },
    {
      "name": "Aguardar tela Pagar",
      "action": "wait",
      "target": [{"texto_contem": ["Pagar", "Pay", "Pagamento"]}, {"classe": "android.widget.TextView"}],
      "timeout": 8,
      "retries": 2,
      "retry_delay": 0.2
    },
    {
      "name": "Clicar em Pagar",
      "action": "click",
      "target": [{"texto_contem": ["Pagar", "Pay", "Confirmar"]}, {"classe": "android.widget.Button"}],
      "timeout": 6,
      "retries": 2,
      "retry_delay": 0.2
    },
    {
      "name": "Aguardar campo de chave Pix",
      "action": "wait",
      "target": [
        {
          "resource_id": "br.com.intermedium:id/2131438611",
          "text": "Chave, Copia e Cola ou Perfil do Fórum"
        },
        {
          "resource_id": "br.com.intermedium:id/2131438611"
        },
        {
          "classe": "android.widget.EditText"
        }
      ],
      "timeout": 8,
      "retries": 2,
      "retry_delay": 0.2
    },
    {
      "name": "Loop: validar chaves Pix",
      "action": "loop",
      "over": "$chaves_pix",
      "var_name": "chave",
      "back_after_each": false,
      "steps": [
        {
          "name": "Verificar se está na tela de chave Pix",
          "action": "if",
          "condicao": [
            {
              "resource_id": "br.com.intermedium:id/2131438611",
              "text": "Chave, Copia e Cola ou Perfil do Fórum"
            },
            {
              "resource_id": "br.com.intermedium:id/2131438611"
            },
            {
              "classe": "android.widget.EditText"
            }
          ],
          "timeout": 10,
          "then": [
            {
              "name": "Limpar campo de chave",
              "action": "type",
              "target": [
                {
                  "resource_id": "br.com.intermedium:id/2131438611",
                  "text": "Chave, Copia e Cola ou Perfil do Fórum"
                },
                {
                  "resource_id": "br.com.intermedium:id/2131438611"
                },
                {
                  "classe": "android.widget.EditText"
                }
              ],
              "value": "",
              "timeout": 5
            },
            {
              "name": "Digitar chave Pix atual",
              "action": "type",
              "target": [
                {
                  "resource_id": "br.com.intermedium:id/2131438611",
                  "text": "Chave, Copia e Cola ou Perfil do Fórum"
                },
                {
                  "resource_id": "br.com.intermedium:id/2131438611"
                },
                {
                  "classe": "android.widget.EditText"
                }
              ],
              "value": "$chave",
              "timeout": 10
            },
            {
              "name": "Aguardar app validar chave",
              "action": "delay",
              "seconds": 3
            },
            {
              "name": "Aguardar botão Continuar",
              "action": "wait",
              "target": [{"texto_contem": ["Continuar", "Continue", "Next", "Avançar"]}, {"classe": "android.widget.Button"}],
              "timeout": 6,
              "retries": 2,
              "retry_delay": 0.2
            },
            {
              "name": "Clicar em Continuar",
              "action": "click",
              "target": [{"texto_contem": ["Continuar", "Continue", "Next", "Avançar"]}, {"classe": "android.widget.Button"}],
              "timeout": 4,
              "retries": 2,
              "retry_delay": 0.2
            },
            {
              "name": "Aguardar próxima tela",
              "action": "delay",
              "seconds": 1
            },
            {
              "name": "Verificar mensagem de erro",
              "action": "if",
              "condicao": [
                {"texto_contem": ["erro", "inválida", " inválido", "incorrect", "invalid"]},
                {"resource_id": "br.com.intermedium:id/2131439570"}
              ],
              "timeout": 5,
              "then": [
                {
                  "name": "Extrair mensagem de erro",
                  "action": "extract",
                  "target": [
                    {"texto_contem": ["erro", "inválida", "inválido", "incorrect", "invalid"]},
                    {"resource_id": "br.com.intermedium:id/2131439570"}
                  ],
                  "save_as": "erro_msg",
                  "timeout": 5
                },
                {
                  "name": "Logar erro da chave",
                  "action": "log",
                  "message": "❌ Chave inválida: $erro_msg"
                },
                {
                  "name": "Voltar para tela de chave",
                  "action": "press_back"
                },
                {
                  "name": "Aguardar tela de chave",
                  "action": "delay",
                  "seconds": 2
                },
                {
                  "name": "Limpar campo de chave",
                  "action": "type",
                  "target": [
                    {
                      "resource_id": "br.com.intermedium:id/2131438611",
                      "text": "Chave, Copia e Cola ou Perfil do Fórum"
                    },
                    {
                      "resource_id": "br.com.intermedium:id/2131438611"
                    },
                    {
                      "classe": "android.widget.EditText"
                    }
                  ],
                  "value": "",
                  "timeout": 5
                }
              ],
              "else": [
                {
                  "name": "Aguardar botão Pagar R$",
                  "action": "wait",
                  "target": [{"texto_contem": ["Pagar R$", "Pagar", "Pay", "Confirmar"]}, {"classe": "android.widget.Button"}],
                  "timeout": 8,
                  "retries": 2,
                  "retry_delay": 0.2,
                  "on_failure": ["press_back", "delay:1"]
                },
                {
                  "name": "Extrair valor do pagamento",
                  "action": "extract",
                  "target": [{"texto_contem": ["Pagar R$", "Pagar", "Pay", "Confirmar"]}, {"classe": "android.widget.Button"}],
                  "save_as": "valor_pagar",
                  "timeout": 4,
                  "retries": 2,
                  "retry_delay": 0.2
                },
                {
                  "name": "Logar valor encontrado",
                  "action": "log",
                  "message": "✅ Chave válida — $valor_pagar"
                },
                {
                  "name": "Clicar em Pagar",
                  "action": "click",
                  "target": [{"texto_contem": ["Pagar R$", "Pagar", "Pay", "Confirmar"]}, {"classe": "android.widget.Button"}],
                  "timeout": 5,
                  "retries": 2,
                  "retry_delay": 0.2
                },
                {
                  "name": "Aguardar tela de confirmação",
                  "action": "delay",
                  "seconds": 1
                },
                {
                  "name": "Verificar alerta de fraude",
                  "action": "if",
                  "condicao": [
                    {"texto_contem": ["fraude", "alerta", "suspeita", "warning"]},
                    {"resource_id": "br.com.intermedium:id/2131429356"}
                  ],
                  "timeout": 10,
                  "then": [
                    {
                      "name": "Logar alerta de fraude",
                      "action": "log",
                      "message": "⚠️ Alerta de fraude — confirmando mesmo assim"
                    },
                    {
                      "name": "Clicar em confirmar mesmo assim",
                      "action": "click",
                      "target": [
                        {"texto_contem": ["fraude", "alerta", "suspeita", "warning", "confirmar"]},
                        {"resource_id": "br.com.intermedium:id/2131429356"}
                      ],
                      "timeout": 5
                    },
                    {
                      "name": "Aguardar após alerta",
                      "action": "delay",
                      "seconds": 2
                    }
                  ],
                  "else": []
                },
                {
                  "name": "Aguardar botão CONFIRMAR",
                  "action": "wait",
                  "target": [{"texto_contem": ["CONFIRMAR", "Confirmar", "Confirm", "OK"]}, {"classe": "android.widget.Button"}],
                  "timeout": 8,
                  "retries": 2,
                  "retry_delay": 0.2
                },
                {
                  "name": "Clicar em CONFIRMAR",
                  "action": "click",
                  "target": [{"texto_contem": ["CONFIRMAR", "Confirmar", "Confirm", "OK"]}, {"classe": "android.widget.Button"}],
                  "timeout": 5,
                  "retries": 2,
                  "retry_delay": 0.2
                },
                {
                  "name": "Aguardar processamento",
                  "action": "delay",
                  "seconds": 2
                },
                {
                  "name": "Aguardar Pix enviado com sucesso",
                  "action": "wait",
                  "target": [{"texto_contem": ["Pix enviado", "Transferência enviada", "Payment sent", "Enviado"]}, {"classe": "android.widget.TextView"}],
                  "timeout": 10,
                  "retries": 2,
                  "retry_delay": 0.2
                },
                {
                  "name": "Logar Pix enviado",
                  "action": "log",
                  "message": "🎉 Pix enviado! ($chave) — $valor_pagar"
                },
                {
                  "name": "Aguardar botão Realizar novo pix",
                  "action": "wait",
                  "target": [{"texto_contem": ["Realizar novo pix", "Fazer novo pix", "New payment", "Nova transferência"]}, {"classe": "android.widget.Button"}],
                  "timeout": 8,
                  "retries": 2,
                  "retry_delay": 0.2
                },
                {
                  "name": "Clicar em Realizar novo pix",
                  "action": "click",
                  "target": [{"texto_contem": ["Realizar novo pix", "Fazer novo pix", "New payment", "Nova transferência"]}, {"classe": "android.widget.Button"}],
                  "timeout": 5,
                  "retries": 2,
                  "retry_delay": 0.2
                },
                {
                  "name": "Aguardar tela de chave",
                  "action": "wait",
                  "target": [
                    {
                      "resource_id": "br.com.intermedium:id/2131438611",
                      "text": "Chave, Copia e Cola ou Perfil do Fórum"
                    },
                    {
                      "resource_id": "br.com.intermedium:id/2131438611"
                    },
                    {
                      "classe": "android.widget.EditText"
                    }
                  ],
                  "timeout": 8,
                  "retries": 2,
                  "retry_delay": 0.2
                },
                {
                  "name": "Aguardar carregamento do campo",
                  "action": "delay",
                  "seconds": 2
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "Logar finalizado",
      "action": "log",
      "message": "🏁 Fluxo Pix finalizado."
    }
  ]
}
